{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Neuro",
  "scopeName": "source.neuro",
  "patterns": [
    { "include": "#comments" },
    { "include": "#triple_strings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#lifetimes" },
    { "include": "#labels" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#structs" },
    { "include": "#enums" },
    { "include": "#traits" },
    { "include": "#impls" },
    { "include": "#type_aliases" },
    { "include": "#newtypes" },
    { "include": "#function_calls" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.neuro",
          "match": "//.*$"
        },
        {
          "name": "comment.block.neuro",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "triple_strings": {
      "name": "string.quoted.triple.neuro",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "patterns": [
        {
          "name": "constant.character.escape.neuro",
          "match": "\\\\."
        },
        {
          "name": "meta.interpolation.neuro",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.neuro" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.neuro" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.neuro",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.neuro",
          "match": "\\\\."
        },
        {
          "name": "meta.interpolation.neuro",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.neuro" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.neuro" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.neuro",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?(bf16|f16|f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.hex.neuro",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
        },
        {
          "name": "constant.numeric.octal.neuro",
          "match": "\\b0[oO][0-7][0-7_]*(i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
        },
        {
          "name": "constant.numeric.binary.neuro",
          "match": "\\b0[bB][01][01_]*(i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
        },
        {
          "name": "constant.numeric.integer.neuro",
          "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|u8|u16|u32|u64|bf16|f16|f32|f64)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.neuro",
          "match": "\\b(if|else|while|for|in|break|continue|return|match|loop)\\b"
        },
        {
          "name": "keyword.declaration.neuro",
          "match": "\\b(func|struct|enum|impl|trait|import|export|module)\\b"
        },
        {
          "name": "keyword.declaration.type.neuro",
          "match": "\\b(type|newtype)\\b"
        },
        {
          "name": "keyword.mutability.neuro",
          "match": "\\b(val|mut|const)\\b"
        },
        {
          "name": "keyword.special.neuro",
          "match": "\\b(self|Self|where|as|dyn|move|unsafe|async|await|spawn|defer|pool)\\b"
        },
        {
          "name": "keyword.operator.error-propagation.neuro",
          "match": "(?<![?])\\?(?![?])"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.neuro",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|bf16|f16|f32|f64|bool|string|char)\\b"
        },
        {
          "name": "storage.type.tensor.neuro",
          "match": "\\b(Tensor|Option|Result|Future|ParameterList|KernelOut|Device)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.neuro",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.neuro",
          "match": "\\b(None|Some|Ok|Err|NaN|Inf)\\b"
        }
      ]
    },
    "lifetimes": {
      "name": "storage.modifier.lifetime.neuro",
      "match": "'[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "labels": {
      "name": "entity.name.label.neuro",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*):\\s*(?=for|while|loop)"
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.neuro",
          "begin": "@",
          "end": "(?=[^a-zA-Z0-9_\\(])|$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.attribute.neuro" }
          },
          "patterns": [
            {
              "name": "storage.modifier.attribute.neuro",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*"
            },
            {
              "name": "meta.attribute.arguments.neuro",
              "begin": "\\(",
              "end": "\\)",
              "patterns": [
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#constants" },
                {
                  "name": "variable.parameter.attribute.neuro",
                  "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                }
              ]
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.neuro",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.compose.neuro",
          "match": ">>"
        },
        {
          "name": "keyword.operator.null-coalesce.neuro",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.arrow.neuro",
          "match": "->"
        },
        {
          "name": "keyword.operator.path.neuro",
          "match": "::"
        },
        {
          "name": "keyword.operator.range.neuro",
          "match": "\\.\\.\\.?=?"
        },
        {
          "name": "keyword.operator.matmul.neuro",
          "match": "@(?![a-zA-Z_])"
        },
        {
          "name": "keyword.operator.compound-assign.neuro",
          "match": "[+\\-*/%&|^]="
        },
        {
          "name": "keyword.operator.comparison.neuro",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.logical.neuro",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.shift.neuro",
          "match": "<<"
        },
        {
          "name": "keyword.operator.bitwise.neuro",
          "match": "[&|^~]"
        },
        {
          "name": "keyword.operator.arithmetic.neuro",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.neuro",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.assignment.neuro",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.not.neuro",
          "match": "!"
        },
        {
          "name": "keyword.operator.deref.neuro",
          "match": "(?<=[\\s=\\(,])\\*(?=[a-zA-Z_])"
        },
        {
          "name": "keyword.operator.borrow.neuro",
          "match": "&(?:mut\\b)?"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.neuro" },
            "2": { "name": "entity.name.function.neuro" }
          }
        }
      ]
    },
    "structs": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.neuro" },
            "2": { "name": "entity.name.type.struct.neuro" }
          }
        }
      ]
    },
    "enums": {
      "patterns": [
        {
          "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.neuro" },
            "2": { "name": "entity.name.type.enum.neuro" }
          }
        }
      ]
    },
    "traits": {
      "patterns": [
        {
          "match": "\\b(trait)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.neuro" },
            "2": { "name": "entity.name.type.trait.neuro" }
          }
        }
      ]
    },
    "impls": {
      "patterns": [
        {
          "match": "\\b(impl)(?:<[^>]*>)?\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s+for\\s+([a-zA-Z_][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.neuro" },
            "2": { "name": "entity.name.type.impl.neuro" },
            "3": { "name": "entity.name.type.neuro" }
          }
        }
      ]
    },
    "type_aliases": {
      "patterns": [
        {
          "match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.neuro" },
            "2": { "name": "entity.name.type.alias.neuro" }
          }
        }
      ]
    },
    "newtypes": {
      "patterns": [
        {
          "match": "\\b(newtype)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.neuro" },
            "2": { "name": "entity.name.type.newtype.neuro" }
          }
        }
      ]
    },
    "function_calls": {
      "patterns": [
        {
          "match": "\\b(?!if|else|while|for|in|break|continue|return|match|loop|val|mut|const|func|struct|enum|impl|trait|import|export|module|type|newtype|self|Self|where|as|dyn|move|unsafe|async|await|spawn|defer|pool\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.neuro" }
          }
        }
      ]
    }
  }
}
